library(ggplot2)
library(reshape2)
set.seed(123)
mat <- matrix(rnorm(100), nrow = 10)
rownames(mat) <- paste0("Feature A", 1:10)
colnames(mat) <- paste0("Feature B", 1:10)
df <- melt(mat)
ggplot(df, aes(Var2, Var1, fill = value)) +
geom_tile() +
scale_fill_gradient2(low = "blue", mid = "white", high = "red") +
geom_text(aes(label = sprintf("%.2f", value))) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(x = "", y = "", fill = "Value")
gc()
ggplot(df, aes(Var2, Var1, fill = value)) +
geom_tile() +
scale_fill_gradient2(low = "blue", mid = "white", high = "red") +
#geom_text(aes(label = sprintf("%.2f", value))) +
geom_text(aes(label = ifelse(abs(value) > 1, round(value,2), ""))) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(x = "", y = "", fill = "Value")
gc()
set.seed(123)
mat <- matrix(rnorm(100), nrow = 10)
rownames(mat) <- paste0("Feature A", 1:10)
colnames(mat) <- paste0("Feature B", 1:10)
df <- melt(mat)
ggplot(df, aes(Var2, Var1, fill = value)) +
geom_tile() +
scale_fill_gradient2(low = "blue", mid = "white", high = "red") +
geom_text(aes(label = sprintf("%.2f", value))) +
#geom_text(aes(label = ifelse(abs(value) > 1, round(value,2), ""))) + # for only showing important values meeting threshold
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(x = "", y = "", fill = "Value")
gc()
